---
import '../styles/global.css';
import '@fontsource/poppins/400.css';
import '@fontsource/poppins/600.css';
import '@fontsource/poppins/700.css';

interface Props {
  title: string;
  description?: string;
  /** Optional Open Graph / Twitter image. Path is resolved against the
   * deployed site URL (Astro.site). Defaults to a generic share image. */
  ogImage?: string;
  /** OG / social card title. Defaults to `title` if omitted. */
  ogTitle?: string;
  /** OG / social card description. Defaults to `description` if omitted. */
  ogDescription?: string;
  /** OG type (`website`, `article`, etc.). Defaults to `website`. */
  ogType?: string;
}

const {
  title,
  description = '',
  ogImage = '/images/og/raport-b24-share.jpg',
  ogTitle = title,
  ogDescription = description,
  ogType = 'website',
} = Astro.props;

// Build absolute URLs for OG (social platforms require fully-qualified URLs).
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
const absoluteOgImage = new URL(ogImage, Astro.site).toString();
---

<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>

    {/* Canonical */}
    <link rel="canonical" href={canonicalUrl} />

    {/* Open Graph (Facebook, LinkedIn, Slack, Discord, etc.) */}
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:width" content="1920" />
    <meta property="og:image:height" content="1008" />
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:site_name" content="Fuse Collective Reports" />

    {/* Twitter / X card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={absoluteOgImage} />

    {/*
      Umami analytics — server-side via Vercel Routing Middleware
      (see /middleware.ts at project root). The client-side <script>
      previously here was blocked by ~30-40% of ad blockers; the edge
      middleware now dispatches the pageview directly to Umami.
    */}
  </head>
  <body class="bg-surface-light text-on-surface-dark font-body">
    <slot />

    {/* LinkedIn Insight Tag — site-wide conversion / retargeting pixel. */}
    <script is:inline type="text/javascript">
      _linkedin_partner_id = "6680233";
      window._linkedin_data_partner_ids = window._linkedin_data_partner_ids || [];
      window._linkedin_data_partner_ids.push(_linkedin_partner_id);
    </script>
    <script is:inline type="text/javascript">
      (function(l) {
        if (!l) {
          window.lintrk = function(a, b) { window.lintrk.q.push([a, b]) };
          window.lintrk.q = [];
        }
        var s = document.getElementsByTagName("script")[0];
        var b = document.createElement("script");
        b.type = "text/javascript"; b.async = true;
        b.src = "https://snap.licdn.com/li.lms-analytics/insight.min.js";
        s.parentNode.insertBefore(b, s);
      })(window.lintrk);
    </script>
    <noscript>
      <img height="1" width="1" style="display:none;" alt="" src="https://px.ads.linkedin.com/collect/?pid=6680233&fmt=gif" />
    </noscript>
  </body>
</html>
