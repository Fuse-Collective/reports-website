---
/**
 * AnalysisHeader — header for area-analysis sections.
 *
 * Visual: full-composition icon (dashed-outlined circle + yellow filled circle
 * + Material-Symbol centre), paired with H1 title + intro paragraph.
 *
 * Figma 3611:12891–12936 — each area's complete "Heading" motif is exported
 * as a single SVG into `src/icons/areas/` and rendered via astro-icon. The
 * yellow (#FECD36) and black (#1D1D1B) are baked in because the composition
 * is fixed across all areas; only the centre Material Symbol varies.
 *
 * The `icon` prop accepts: `areas/target-click`, `areas/eye-scan`,
 * `areas/dna-helix`, `areas/shopping-bag`, `areas/magic-wand`, `areas/robot`.
 */
import { Icon } from 'astro-icon/components';

interface Props {
  icon: string;
  title: string;
  intro: string;
  class?: string;
}

const { icon, title, intro, class: className } = Astro.props;

// Split title on the first ":" so we can render the lead bold and the rest
// on a new line (without the colon). Titles without ":" render as one line.
const colonIdx = title.indexOf(':');
const titleLead = colonIdx >= 0 ? title.slice(0, colonIdx).trim() : title.trim();
const titleRest = colonIdx >= 0 ? title.slice(colonIdx + 1).trim() : '';
---

<header class:list={['flex flex-col gap-standard', className]}>

  <div class="grid gap-standard lg:grid-cols-[258px_1fr] lg:gap-relaxed lg:items-start">

    {/* Full-composition area icon (dashed circle + yellow dot + centre symbol) */}
    <Icon name={icon} class="w-[258px] h-[149px] shrink-0" aria-hidden="true" />

    {/* Title — lead (bold) on first line, rest on a new line if ":" splits it */}
    <h2 class="font-body text-headline-md lg:text-display-lg font-normal leading-normal text-on-surface-dark m-0 flex flex-col">
      <span class="font-bold">{titleLead}</span>
      {titleRest && <span>{titleRest}</span>}
    </h2>
  </div>

  {/* Intro paragraph — full width under both columns */}
  <p class="font-body text-body-md font-normal leading-normal text-on-surface-dark m-0">
    {intro}
  </p>

</header>
