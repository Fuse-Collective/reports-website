---
/**
 * InsightRow — a single "Główne wnioski" row:
 *   title (left) | decorative vertical pill (centre) | description (right)
 *
 * The vertical pill is purely decorative per Figma (3644:21487 — dark-outlined
 * capsule 40×116 with a yellow 24×24 circle pinned at the top). No props drive it.
 *
 * Bottom border divides rows when stacked.
 */

interface Props {
  title: string;
  description: string;
  class?: string;
}

const { title, description, class: className } = Astro.props;
---

<div class:list={[
  'grid gap-relaxed py-relaxed',
  'grid-cols-[40px_1fr]',
  'lg:grid-cols-[minmax(0,360fr)_40px_minmax(0,532fr)] lg:gap-comfortable lg:px-relaxed',
  className,
]}>

  {/* Title — right-aligned at lg+ per Figma (textH:RIGHT, fs:26, fw:400).
      Desktop column proportions 360:40:532 match Figma Border frame (1028px
      inner content area = 360 + 48 + 40 + 48 + 532).
      Mobile: title in column 2, pill spans rows 1-2 of column 1. */}
  <h3 class="col-start-2 row-start-1 lg:col-start-1 lg:row-start-1 lg:text-right font-body text-body-md font-normal leading-normal text-on-surface-dark m-0">
    {title}
  </h3>

  {/* Decorative accent pill — left-column marker on mobile, centre on desktop */}
  <span
    class="col-start-1 row-start-1 row-span-2 lg:col-start-2 lg:row-span-1 self-start flex w-10 h-[116px] items-start justify-center pt-tight rounded-full border-[1.6px] border-on-surface-dark"
    aria-hidden="true"
  >
    <span class="w-6 h-6 rounded-full bg-primary"></span>
  </span>

  {/* Description */}
  <p class="col-start-2 row-start-2 lg:col-start-3 lg:row-start-1 font-body text-body font-normal leading-normal text-on-surface-dark m-0">
    {description}
  </p>

</div>
