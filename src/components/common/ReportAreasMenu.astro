---
/**
 * ReportAreasMenu — shared markup for the report TOC menu.
 * Used inline inside OverviewSection, wrapped for sticky/drawer behavior
 * inside ReportSideNav, and inside MenuScope (desktop overlay).
 *
 * Two modes (controls which part is expanded):
 *   - `areas` (default): areas list expanded at the top, trailing section
 *     pills (e.g. Konstelacje, Ocena) shown as collapsed locked pills.
 *   - `constellations`: areas pill collapsed at the top; the FIRST section
 *     pill (Konstelacje) expanded — header pill + list of its `items`;
 *     subsequent pills collapsed. Used in the second TOC scope (next to
 *     the preview-gate insight) — the reader has moved past the analyses,
 *     so the areas list is folded away and attention shifts to what's
 *     being unlocked.
 *
 * Scroll-spy: each area `<li>` carries `data-area-number`. The page-level
 * script in [slug].astro watches `[data-section-type="analysis"]` and sets
 * `data-current="true"` on matching items — applied across both desktop
 * overlays + the mobile drawer.
 */
import { Icon } from 'astro-icon/components';

interface Area {
  number: string;
  label: string;
  state: 'done' | 'current';
  href?: string;
}

interface SectionPillItem {
  number: string;
  label: string;
  href?: string;
}

interface SectionPill {
  label: string;
  state: 'locked';
  href?: string;
  items?: SectionPillItem[];
}

interface Props {
  areasLabel: string;
  areas: Area[];
  areasHref?: string;
  sectionPills?: SectionPill[];
  mode?: 'areas' | 'constellations';
  class?: string;
}

const {
  areasLabel,
  areas,
  areasHref,
  sectionPills = [],
  mode = 'areas',
  class: className,
} = Astro.props;
---

<div class:list={["flex flex-col gap-standard items-start", className]}>

  {/* Section 1 — Areas. Header pill always shown; items list only when
      mode === 'areas'. */}
  <div class="flex flex-col gap-standard items-start">
    {areasHref ? (
      <a
        href={areasHref}
        class="rounded-full focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary"
      >
        <div class="inline-flex items-center gap-tight rounded-full bg-surface-light border border-outline-light pl-tight pr-[10px] py-tight">
          <Icon name="areas-indicator" class="w-6 h-6 shrink-0 text-on-surface-dark" />
          <span class="font-body text-label-sm font-semibold uppercase tracking-wider text-on-surface-dark">
            {areasLabel}
          </span>
        </div>
      </a>
    ) : (
      <div class="inline-flex items-center gap-tight rounded-full bg-surface-light border border-outline-light pl-tight pr-[10px] py-tight">
        <Icon name="areas-indicator" class="w-6 h-6 shrink-0 text-on-surface-dark" />
        <span class="font-body text-label-sm font-semibold uppercase tracking-wider text-on-surface-dark">
          {areasLabel}
        </span>
      </div>
    )}

    {mode === 'areas' && (
      <ul class="flex flex-col gap-compact m-0 p-0 list-none">
        {areas.map((area) => {
          const href = area.href ?? `#analysis-${area.number}`;
          return (
            <li
              data-area-number={area.number}
              data-current={area.state === 'current' ? 'true' : 'false'}
              class="group"
            >
              <a
                href={href}
                class="inline-flex items-center gap-standard rounded-full focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary"
              >
                {/* Number slot — same 32×32 dimensions both states; fill switches on current */}
                <span class="inline-flex w-8 h-8 items-center justify-center rounded-full font-body text-label-sm font-normal leading-none tabular-nums text-on-surface-dark on-dark:text-on-surface-light group-data-[current=true]:bg-surface-dark group-data-[current=true]:text-on-surface-light on-dark:group-data-[current=true]:bg-surface-light on-dark:group-data-[current=true]:text-on-surface-dark">
                  <span class="group-data-[current=true]:translate-y-[1px] group-data-[current=true]:-translate-x-[1px]">{area.number}</span>
                </span>
                <span class="font-body text-label-sm font-normal text-on-surface-dark on-dark:text-on-surface-light group-data-[current=true]:font-semibold">
                  {area.label}
                </span>
              </a>
            </li>
          );
        })}
      </ul>
    )}
  </div>

  {/* Sections 2+ — locked section pills. Each is rendered with the same
      structure as Section 1 (header pill + optional items list). In
      `constellations` mode the first section pill's items are shown. */}
  {sectionPills.map((pill, i) => {
    const expanded = mode === 'constellations' && i === 0 && pill.items && pill.items.length > 0;
    const pillInner = (
      <div class="inline-flex items-center gap-tight rounded-full bg-surface-light border border-outline-light pl-tight pr-[10px] py-tight">
        <span class="inline-flex w-6 h-6 items-center justify-center rounded-full bg-primary text-on-surface-dark shrink-0">
          <Icon name="padlock-mini" class="w-6 h-6" />
        </span>
        <span class="font-body text-label-sm font-semibold uppercase tracking-wider text-on-surface-dark">
          {pill.label}
        </span>
      </div>
    );
    return (
      <div class="flex flex-col gap-standard items-start">
        {pill.href ? (
          <a
            href={pill.href}
            class="rounded-full focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary"
          >
            {pillInner}
          </a>
        ) : pillInner}

        {expanded && (
          <ul class="flex flex-col gap-compact m-0 p-0 list-none">
            {pill.items!.map((item) => {
              const href = item.href ?? `#constellation-${item.number}`;
              return (
                <li
                  data-constellation-number={item.number}
                  data-current="false"
                  class="group"
                >
                  <a
                    href={href}
                    class="inline-flex items-center gap-standard rounded-full focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary"
                  >
                    <span class="inline-flex w-8 h-8 items-center justify-center rounded-full font-body text-label-sm font-normal leading-none tabular-nums text-on-surface-dark on-dark:text-on-surface-light group-data-[current=true]:bg-surface-dark group-data-[current=true]:text-on-surface-light on-dark:group-data-[current=true]:bg-surface-light on-dark:group-data-[current=true]:text-on-surface-dark">
                      <span class="group-data-[current=true]:translate-y-[1px] group-data-[current=true]:-translate-x-[1px]">{item.number}</span>
                    </span>
                    <span class="font-body text-label-sm font-normal text-on-surface-dark on-dark:text-on-surface-light group-data-[current=true]:font-semibold">
                      {item.label}
                    </span>
                  </a>
                </li>
              );
            })}
          </ul>
        )}
      </div>
    );
  })}

</div>
