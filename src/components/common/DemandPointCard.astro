---
/**
 * DemandPointCard — one demand point: category tag + customer quote.
 *
 * Typically rendered 3× in a ConstellationFoundation block. Quote text is
 * rendered as-is (YAML supplies the Polish quote marks „…").
 */
import Tag from '../ui/Tag.astro';

interface Props {
  tag: string;
  tagTone?: 'accent' | 'neutral';
  quote: string;
}

const { tag, tagTone = 'accent', quote } = Astro.props;
---

<div class="flex flex-col gap-standard">
  <Tag label={tag} tone={tagTone} class="self-start" />
  <p class="font-body text-body font-normal leading-normal text-on-surface-dark m-0">
    {quote}
  </p>
</div>
