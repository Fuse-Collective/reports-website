---
/**
 * ReportSideNav — mobile chapter-menu (TOC) dropdown (below xl).
 *
 * xl+ (>=1280px): the menu sits inline inside the menu-scope wrapper in
 * [slug].astro as a sticky right column. This component renders NOTHING.
 *
 * Below xl: a floating "Spis treści" pill trigger sits bottom-right. Clicking
 * it toggles a compact panel that appears directly above the trigger — the
 * panel is constrained in width (not full-screen) so it reads like a popover.
 * The trigger's label stays visible; only the left icon swaps (areas-indicator
 * → × close). The same button opens and closes the panel.
 *
 * Visibility: the root wrapper fades in after the reader has scrolled past
 * the primary overview hero and fades out once the closing strategic-assessment
 * section is in view. Scroll listener (not IntersectionObserver) handles
 * anchor-jump teleports reliably.
 */
import { Icon } from 'astro-icon/components';
import ReportAreasMenu from '../common/ReportAreasMenu.astro';

interface Area {
  number: string;
  label: string;
  state: 'done' | 'current';
  href?: string;
}

interface SectionPill {
  label: string;
  state: 'locked';
}

interface Props {
  areasLabel: string;
  areas: Area[];
  areasHref?: string;
  sectionPills?: SectionPill[];
}

const { areasLabel, areas, areasHref, sectionPills = [] } = Astro.props;
---

<div
  data-sidenav-root
  class="xl:hidden fixed bottom-[20px] right-[20px] z-40 flex flex-col items-end gap-standard opacity-0 pointer-events-none transition-opacity duration-300"
>

  {/* Panel — sits above the trigger, constrained width */}
  <div
    id="report-sidenav-panel"
    data-sidenav-panel
    class="w-[min(320px,calc(100vw-40px))] max-h-[calc(100vh-140px)] overflow-y-auto rounded-[24px] bg-surface-accent shadow-[0_8px_24px_rgba(29,29,27,0.24)] p-relaxed"
    data-surface="accent"
    role="region"
    aria-label="Spis treści raportu"
    hidden
  >
    <ReportAreasMenu
      areasLabel={areasLabel}
      areas={areas}
      areasHref={areasHref}
      sectionPills={sectionPills}
    />
  </div>

  {/* Trigger — always visible; clicking toggles the panel. Left icon
      swaps between areas-indicator and × via group-aria-expanded. */}
  <button
    type="button"
    data-sidenav-trigger
    class="group inline-flex items-center gap-compact rounded-full bg-surface-dark pl-tight pr-standard py-tight shadow-[0_8px_24px_rgba(29,29,27,0.24)]"
    aria-expanded="false"
    aria-controls="report-sidenav-panel"
    aria-label="Spis treści"
  >
    <span class="inline-flex w-8 h-8 items-center justify-center rounded-full bg-primary text-on-surface-dark shrink-0">
      <Icon name="areas-indicator" is:inline class="w-6 h-6 group-aria-expanded:hidden" />
      <Icon name="close" is:inline class="w-6 h-6 hidden group-aria-expanded:inline-block" />
    </span>
    <span class="font-body text-label-sm font-semibold uppercase tracking-wider text-on-surface-light">
      Spis treści
    </span>
  </button>

</div>

<script>
  const root = document.querySelector<HTMLElement>('[data-sidenav-root]');
  const trigger = document.querySelector<HTMLButtonElement>('[data-sidenav-trigger]');
  const panel = document.querySelector<HTMLElement>('[data-sidenav-panel]');
  const overview = document.querySelector<HTMLElement>('[data-section-type="overview-hero"]');
  const menuEnd = document.querySelector<HTMLElement>('#ocena-strategiczna');

  const setRootVisible = (visible: boolean) => {
    if (!root) return;
    root.classList.toggle('opacity-0', !visible);
    root.classList.toggle('pointer-events-none', !visible);
  };

  const setPanelOpen = (open: boolean) => {
    if (!trigger || !panel) return;
    trigger.setAttribute('aria-expanded', String(open));
    panel.hidden = !open;
  };

  // Scroll-driven trigger visibility (same rules as before).
  const update = () => {
    const y = window.scrollY;
    const overviewBottom = overview ? y + overview.getBoundingClientRect().bottom : 0;
    const endTop = menuEnd ? y + menuEnd.getBoundingClientRect().top : Infinity;
    const pastOverview = y >= overviewBottom;
    const atOrPastEnd = y + window.innerHeight * 0.2 >= endTop;
    const visible = pastOverview && !atOrPastEnd;
    setRootVisible(visible);
    if (!visible && trigger?.getAttribute('aria-expanded') === 'true') {
      setPanelOpen(false);
    }
  };

  update();
  window.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', update);

  trigger?.addEventListener('click', () => {
    const isOpen = trigger.getAttribute('aria-expanded') === 'true';
    setPanelOpen(!isOpen);
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && trigger?.getAttribute('aria-expanded') === 'true') {
      setPanelOpen(false);
      trigger.focus();
    }
  });

  // Click outside the root closes the panel.
  document.addEventListener('click', (e) => {
    if (!root || !trigger) return;
    if (trigger.getAttribute('aria-expanded') !== 'true') return;
    const target = e.target as Node;
    if (!root.contains(target)) setPanelOpen(false);
  });
</script>
