---
/**
 * SectionIntro — section intro header, two layouts.
 *
 * Layouts:
 *   'split' (default) — self-contained 50/50 grid. Headline left, body right.
 *                       Use when the intro IS the whole section header.
 *   'stacked-left'    — renders ONLY a vertical stack (headline + optional
 *                       indicator + body). No outer grid, no slot. The host
 *                       wraps it in its own grid and provides sibling content
 *                       (e.g. symptom grid, cards). This way the host controls
 *                       column ratio and layout.
 *
 * Indicator options:
 *   'right' | true  — indicator-circle above body (split layout)
 *   'left'          — indicator-circle below headline (split or stacked-left)
 *   'arrow'         — arrow-right-long between headline and body (stacked-left)
 *
 * Surface-aware via on-dark:/on-accent: — inherits from parent data-surface.
 */
import type { HTMLAttributes } from 'astro/types';
import { Icon } from 'astro-icon/components';

type Layout = 'split' | 'stacked-left';
type Indicator = boolean | 'left' | 'right' | 'arrow';

interface Props extends HTMLAttributes<'div'> {
  headline: string;
  body?: string;
  indicator?: Indicator;
  layout?: Layout;
  as?: 'h1' | 'h2';
}

const {
  headline,
  body,
  indicator = false,
  layout = 'split',
  as: Tag = 'h2',
  class: className,
  ...rest
} = Astro.props;

const hasLeftExtra = Astro.slots.has('left-extra');
const indicatorPos: 'left' | 'right' | 'arrow' | null =
  indicator === true ? 'right' : (indicator || null);

const headlineClass =
  "font-body font-normal text-on-surface-dark on-dark:text-on-surface-light on-accent:text-on-surface-accent text-headline-sm leading-normal lg:text-display-lg lg:leading-normal";

// Body shares color with the headline (Figma #1D1D1B = on-surface-dark).
// Surface-aware: on dark → light, on accent → accent-text.
const bodyClass =
  "font-body text-body leading-relaxed lg:text-body-lg lg:leading-normal text-on-surface-dark on-dark:text-on-surface-light on-accent:text-on-surface-accent";

const circleClass =
  "shrink-0 w-[80px] h-[80px] lg:w-[120px] lg:h-[120px] text-on-surface-dark on-dark:text-on-surface-light on-accent:text-on-surface-accent";

const arrowClass =
  "shrink-0 w-[140px] h-auto lg:w-[218px] text-on-surface-dark on-dark:text-on-surface-light on-accent:text-on-surface-accent";
---

{layout === 'stacked-left' ? (
  <div class:list={["flex flex-col gap-comfortable", className]} {...rest}>
    <Tag class={headlineClass} set:html={headline} />

    {indicatorPos === 'arrow' && (
      <Icon name="arrow-right-long" class={arrowClass} />
    )}
    {indicatorPos === 'left' && (
      <Icon name="indicator-circle" class={circleClass} />
    )}

    {body && (
      <p class={bodyClass} set:html={body}></p>
    )}

    {hasLeftExtra && <slot name="left-extra" />}
  </div>
) : (
  <div class:list={["grid grid-cols-1 lg:grid-cols-2 gap-relaxed", className]} {...rest}>
    <div class:list={["flex flex-col", (hasLeftExtra || indicatorPos === 'left') && "gap-comfortable"]}>
      <Tag class={headlineClass} set:html={headline} />
      {indicatorPos === 'left' && (
        <Icon name="indicator-circle" class={circleClass} />
      )}
      {hasLeftExtra && <slot name="left-extra" />}
    </div>
    <div class="flex flex-col gap-comfortable">
      {indicatorPos === 'right' && (
        <Icon name="indicator-circle" class={circleClass} />
      )}
      {body && (
        <p class={bodyClass}>
          {body}
        </p>
      )}
    </div>
  </div>
)}
