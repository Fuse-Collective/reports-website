---
/**
 * Bullet — square marker for unordered lists, with two sizes.
 *
 * Sizes:
 *   - `lg` (default) — 12×12. Paired with `text-body` via `mt-[0.45em]` on
 *     the bullet to land on the cap line. Used in OverviewInsight /
 *     PreviewGate lists.
 *   - `sm`           —  4×4. Smaller/footnote-style lists. Pair with a
 *     tighter cap offset (~`mt-[0.65em]`) and retune if text size changes.
 *
 * Surface-adaptive fill via `on-dark:` / `on-accent:` prefixes. The mapping
 * intentionally differs from the text-color convention — on accent (yellow),
 * bullets are WHITE for contrast (confirmed against Figma 2026-04-23), NOT
 * `on-surface-accent` (#191919) like body text uses:
 *
 *   - `light` / `muted`  →  `bg-on-surface-dark`   (#191919)
 *   - `dark`             →  `bg-on-surface-light`  (#FFFFFF)
 *   - `accent`           →  `bg-on-surface-light`  (#FFFFFF)  ← divergent
 *
 * If a future section needs a different color, add a `variant` prop rather
 * than inlining overrides.
 *
 * Intended usage — wrap each list item in a flex row with the bullet + text:
 *
 *   <ul class="flex flex-col gap-compact m-0 p-0 list-none">
 *     <li class="flex gap-standard items-start">
 *       <Bullet class="mt-[0.45em]" />
 *       <span>List item text</span>
 *     </li>
 *   </ul>
 */
interface Props {
  size?: 'sm' | 'lg';
  /** Fill variant.
   *   'default' — surface-adaptive (dark on light/muted, white on dark/accent).
   *   'accent'  — always yellow (bg-primary). Use on light surfaces where the
   *               dark square feels heavy and an accent pop reads better. */
  variant?: 'default' | 'accent';
  class?: string;
}

const { size = 'lg', variant = 'default', class: className } = Astro.props;

const sizeClass = size === 'sm' ? 'w-[4px] h-[4px]' : 'w-[12px] h-[12px]';

const variantClass =
  variant === 'accent'
    ? 'bg-primary'
    : 'bg-on-surface-dark on-dark:bg-on-surface-light on-accent:bg-on-surface-light';
---

<span
  class:list={[
    'inline-block shrink-0',
    sizeClass,
    variantClass,
    className,
  ]}
  aria-hidden="true"
></span>
