---
/**
 * ServicesSection — SectionIntro header + 3×2 grid of bordered service cards.
 *
 * Figma sources:
 *   Desktop: 912:17979 (1920px, bg-surface-dark)
 *   Mobile:  1253:34937 (360px, single column)
 *
 * Surface variants via data-surface attribute.
 */
import SectionIntro from '../../ui/SectionIntro.astro';
import ServiceCard from './ServiceCard.astro';
import Button from '../../ui/Button.astro';
import { Icon } from 'astro-icon/components';

interface Service {
  heading: string;
  icon?: string;
  description: string;
}

interface Cta {
  label: string;
  href: string;
  variant?: 'primary' | 'secondary';
}

interface SourceLink {
  label: string;
  href: string;
}

type Surface = 'light' | 'muted' | 'dark' | 'accent';
type IndicatorPos = boolean | 'left' | 'right' | 'arrow';

interface Props {
  /** Optional — when omitted, SectionIntro is skipped entirely. */
  headline?: string;
  body?: string;
  services: Service[];
  as?: 'h1' | 'h2';
  surface?: Surface;
  numbered?: boolean;
  anchorId?: string;
  indicatorPos?: IndicatorPos;
  cta?: Cta;
  sourceLink?: SourceLink;
  sourceNote?: string;
  /** When rendered inside a `<MenuScope>`, set to true to reserve the 368px
   * right-rail space so content doesn't collide with the floating overlay. */
  inMenuScope?: boolean;
}

const {
  headline,
  body,
  services,
  as: headingTag = 'h2',
  surface = 'dark',
  numbered = false,
  anchorId,
  indicatorPos,
  cta,
  sourceLink,
  sourceNote,
  inMenuScope = false,
} = Astro.props;

const bgMap: Record<Surface, string> = {
  light: 'bg-surface-light',
  muted: 'bg-surface-muted',
  dark: 'bg-surface-dark',
  accent: 'bg-surface-accent',
};

const buttonSurface: 'light' | 'accent' | 'dark' =
  surface === 'accent' ? 'accent' : surface === 'dark' ? 'dark' : 'light';

const indicator: IndicatorPos = indicatorPos !== undefined ? indicatorPos : true;
const hasHeaderExtras = !!(cta || sourceLink || sourceNote);
---

<section
  id={anchorId}
  class:list={[bgMap[surface], "py-comfortable lg:py-monumental", anchorId && 'scroll-mt-relaxed']}
  data-surface={surface}
  data-section-type="services"
>
  <div class="px-page-gutter"><div class:list={['mx-auto max-w-content-max', inMenuScope && 'xl:pr-[368px]']}>

    {headline && (
      <SectionIntro
        headline={headline}
        body={body}
        indicator={indicator}
        as={headingTag}
      >
        {(sourceLink || sourceNote) && (
          <div slot="left-extra" class="flex flex-col gap-tight mt-comfortable">
            {sourceLink && (
              <Button variant="text-link" surface={buttonSurface} href={sourceLink.href}>
                <Icon name="book" slot="icon" />
                {sourceLink.label}
              </Button>
            )}
            {sourceNote && (
              <p class="font-body text-[12px] leading-[16px] font-[500] text-on-surface-dark on-dark:text-on-surface-light on-accent:text-on-surface-accent m-0">
                {sourceNote}
              </p>
            )}
          </div>
        )}
        {cta && (
          <div slot="right-extra" class="mt-compact">
            <Button
              variant={cta.variant ?? 'primary'}
              surface={buttonSurface}
              href={cta.href}
            >
              <Icon name="arrow-up-right" slot="icon" />
              {cta.label}
            </Button>
          </div>
        )}
      </SectionIntro>
    )}

    <div class:list={[
      "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3",
      headline && "mt-[72px]",
      services.length > 3
        ? "md:[grid-template-rows:repeat(6,auto)] lg:[grid-template-rows:repeat(6,auto)]"
        : "md:[grid-template-rows:repeat(3,auto)] lg:[grid-template-rows:repeat(3,auto)]",
      "border-r border-b border-outline-dark on-dark:border-outline-white on-accent:border-on-surface-accent"
    ]}>
      {services.map((service, i) => (
        <ServiceCard
          heading={service.heading}
          icon={service.icon}
          label={numbered ? String(i + 1).padStart(2, '0') : undefined}
          description={service.description}
        />
      ))}
    </div>

  </div></div>
</section>
