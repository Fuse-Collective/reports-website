---
/**
 * OverviewSection — thin composition of OverviewHero + OverviewInsight.
 *
 * The two halves are split because on the live report page ([slug].astro),
 * the page-level sticky TOC overlay starts at the INSIGHT row, not at the
 * hero. To achieve that, the `data-menu-scope` boundary must fall BETWEEN
 * the hero and the insight — so [slug].astro imports and renders
 * OverviewHero + OverviewInsight directly with the scope wrapper between
 * them.
 *
 * This wrapper component exists for preview / documentation use (e.g. the
 * design-system/sections page), where the TOC overlay is absent and both
 * halves should render together.
 */
import OverviewHero from './OverviewHero.astro';
import OverviewInsight from './OverviewInsight.astro';

type Surface = 'accent' | 'dark';

interface Area {
  number: string;
  label: string;
  state: 'done' | 'current';
  href?: string;
}

interface SectionPill {
  label: string;
  state: 'locked';
}

interface Cta {
  label: string;
  href: string;
  note?: string;
}

interface Props {
  headline: string;
  subtitle?: string;
  insightLabel: string;
  insight?: string;
  insightPoints?: string[];
  cta?: Cta;
  surface?: Surface;
  // Accepted for interface parity with the YAML shape, but rendered by the
  // page-level TOC overlay (not by Overview itself).
  areasLabel?: string;
  areas?: Area[];
  sectionPills?: SectionPill[];
}

const {
  headline,
  subtitle,
  insightLabel,
  insight,
  insightPoints,
  cta,
  surface = 'accent',
} = Astro.props;

// Standalone composition (DS preview, SectionRenderer fallback). On the
// actual report page, [slug].astro renders Hero and Insight directly —
// Insight gets wrapped in MenuScope and receives inMenuScope={true} there.
---

<OverviewHero headline={headline} subtitle={subtitle} surface={surface} />
<OverviewInsight insightLabel={insightLabel} insight={insight} insightPoints={insightPoints} cta={cta} surface={surface} />
