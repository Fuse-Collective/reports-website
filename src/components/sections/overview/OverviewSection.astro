---
/**
 * OverviewSection — full-yellow hero-style summary with a key insight.
 *
 * Top row: headline + subtitle (2-col).
 * Divider.
 * Bottom row: insight + CTA (full width). The 6-area TOC menu is rendered
 * once at page level in [slug].astro (sticky right column starting from
 * the first analysis section) — not inline here — so we don't duplicate it.
 *
 * Figma: 3611:9539 (workaround_mode: no Variables, non-semantic layer names).
 */
import { Icon } from 'astro-icon/components';

interface Area {
  number: string;
  label: string;
  state: 'done' | 'current';
  href?: string;
}

interface SectionPill {
  label: string;
  state: 'locked';
}

interface Props {
  headline: string;
  subtitle: string;
  insightLabel: string;
  insight: string;
  areasLabel: string;
  areas: Area[];
  sectionPills?: SectionPill[];
}

const {
  headline,
  subtitle,
  insightLabel,
  insight,
  areasLabel,
  areas,
  sectionPills = [],
} = Astro.props;
---

<section
  class="bg-surface-accent py-monumental px-page-gutter"
  data-surface="accent"
  data-section-type="overview"
>
  <div class="mx-auto max-w-content-max flex flex-col gap-comfortable xl:pr-[368px]">

    {/* Top row — headline + subtitle */}
    <div class="grid gap-relaxed lg:grid-cols-2 lg:gap-comfortable">
      <h2 class="font-body text-display-md lg:text-display-lg font-normal leading-normal text-on-surface-accent m-0">
        {headline}
      </h2>
      <p class="font-body text-body-md lg:text-body-lg font-normal leading-tight text-on-surface-accent m-0 lg:pt-compact">
        {subtitle}
      </p>
    </div>

    {/* Divider */}
    <hr class="border-0 border-t border-on-surface-accent/40 m-0" />

    {/* Insight row (full width — menu lives at page level, not here) */}
    <div class="flex flex-col gap-relaxed lg:flex-row lg:gap-relaxed lg:items-start">
      <div class="w-[148px] h-[148px] shrink-0 text-on-surface-accent">
        <Icon name="indicator-circle" class="w-full h-full" />
      </div>
      <div class="flex flex-col gap-relaxed max-w-[893px]">
        <h3 class="font-body text-headline-md lg:text-body-xl font-medium leading-tight text-on-surface-accent m-0">
          {insightLabel}
        </h3>
        <p class="font-body text-body font-normal leading-normal text-on-surface-accent m-0">
          {insight}
        </p>
      </div>
    </div>

  </div>
</section>
