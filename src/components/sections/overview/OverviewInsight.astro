---
/**
 * OverviewInsight — bottom half of the Overview: key insight + CTA.
 *
 * Surface variants:
 *   'accent' (default) — primary pre-gate overview (yellow).
 *   'dark'             — post-gate overview (black, white text, no CTA).
 *
 * Lives INSIDE `data-menu-scope` in [slug].astro as its first child — so the
 * page-level sticky TOC overlay's natural top aligns with this component's
 * top edge (see aside `pt-0` in [slug].astro). Reserves `xl:pr-[368px]` on
 * the inner content wrapper so text doesn't collide with the menu rail.
 *
 * `xl:min-h-[448px]` sizes the inner wrapper to match the TOC menu's measured
 * content height (6 areas + 2 locked section pills + label pill) so the menu
 * fits entirely on the surface. Section total height = 448 (inner min-h) +
 * 112 (pb-monumental) = 560px. If the YAML adds more areas or pills in
 * future reports, re-measure and bump this value — otherwise the menu will
 * spill onto the next section's surface.
 *
 * Paired with OverviewHero on the same surface.
 */
import { Icon } from 'astro-icon/components';
import Button from '../../ui/Button.astro';
import Bullet from '../../ui/Bullet.astro';

type Surface = 'accent' | 'dark';

interface Cta {
  label: string;
  href: string;
  note?: string;
}

interface Props {
  insightLabel: string;
  /** Prose paragraph under the label. Optional — preview-gate omits it and
   * goes straight from label into bullets. */
  insight?: string;
  insightPoints?: string[];
  cta?: Cta;
  surface?: Surface;
  /** When true, reserves 368px on the right at xl+ so content doesn't collide
   * with the page-level sticky TOC overlay. Only anchor-of-scope inserts
   * (primary overview insight, post-gate dark overview insight) need this;
   * standalone renders (preview-gate, DS preview) leave it false. */
  inMenuScope?: boolean;
}

const { insightLabel, insight, insightPoints, cta, surface = 'accent', inMenuScope = false } = Astro.props;

const bgClass = surface === 'dark' ? 'bg-surface-dark' : 'bg-surface-accent';

const textClass =
  'text-on-surface-dark on-dark:text-on-surface-light on-accent:text-on-surface-accent';
---

<section
  class:list={[bgClass, "pb-monumental px-page-gutter"]}
  data-surface={surface}
  data-section-type="overview-insight"
>
  <div class:list={["mx-auto max-w-content-max xl:min-h-[448px]", inMenuScope && "xl:pr-[368px]"]}>

    <div class="flex flex-col gap-relaxed lg:flex-row lg:gap-relaxed lg:items-start">
      <div class:list={["w-[148px] h-[148px] shrink-0", textClass]}>
        <Icon name="indicator-circle" class="w-full h-full" />
      </div>
      <div class="flex flex-col gap-relaxed max-w-[893px]">
        <h3 class:list={["font-body text-headline-md lg:text-body-xl font-medium leading-tight m-0", textClass]}>
          {insightLabel}
        </h3>
        {insight && (
          <p class:list={["font-body text-body font-normal leading-normal m-0", textClass]}>
            {insight}
          </p>
        )}

        {insightPoints && insightPoints.length > 0 && (
          <ul class="flex flex-col gap-compact m-0 p-0 list-none">
            {insightPoints.map((point) => (
              <li class="flex gap-standard items-start">
                <Bullet class="mt-[calc(0.45em+1px)]" />
                <span
                  class:list={["font-body text-body font-normal leading-normal", textClass]}
                  set:html={point}
                ></span>
              </li>
            ))}
          </ul>
        )}

        {cta && (
          <div class="flex flex-col gap-standard">
            <Button variant="primary" surface={surface} href={cta.href}>
              {cta.label}
              <svg slot="icon" viewBox="0 0 64 64" fill="none">
                <rect x="14" y="32" width="36" height="24" rx="2" stroke="currentColor" stroke-width="2"/>
                <path d="M22 32V22C22 14.268 27.268 9 34 9V9C40.732 9 46 14.268 46 22V32" stroke="currentColor" stroke-width="2" stroke-linecap="square"/>
                <circle cx="32" cy="44" r="3" stroke="currentColor" stroke-width="2"/>
              </svg>
            </Button>
            {cta.note && (
              <p class:list={["font-body text-label-sm leading-loose m-0", textClass]}>
                {cta.note}
              </p>
            )}
          </div>
        )}
      </div>
    </div>

  </div>
</section>
