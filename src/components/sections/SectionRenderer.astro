---
/**
 * Dispatcher — renders the correct section template based on section.type.
 * Built sections get their own component; unbuilt ones show a placeholder.
 */
import ReportCoverBoldSection from './report-cover/ReportCoverBoldSection.astro';
import ChapterTitleSection from './chapter-title/ChapterTitleSection.astro';
import PainBlockSection from './pain-block/PainBlockSection.astro';
import OverviewSection from './overview/OverviewSection.astro';
import PreviewGateSection from './preview-gate/PreviewGateSection.astro';
import MethodologySection from './methodology/MethodologySection.astro';
import AnalysisSection from './analysis/AnalysisSection.astro';
import ConstellationSection from './constellation/ConstellationSection.astro';
import OfferCardsSection from './offer-cards/OfferCardsSection.astro';
import ServicesSection from './services/ServicesSection.astro';

interface Props {
  section: Record<string, unknown>;
}

const { section } = Astro.props;
const type = section.type as string;
const headline = (section as Record<string, unknown>).headline as string | undefined;

/* Map YAML report-cover → ReportCoverBoldSection props.
 * Splits "42,6 mln zł" → value="42,6" + unit="mln zł" (regex on first space).
 * `note` (e.g. "+21% r/r") becomes `delta`. Profile-style cells (no note)
 * pass through cleanly — Bold renders the unit beside value either way. */
let boldProps: any = null;
if (type === 'report-cover') {
  const s = section as any;
  const splitValue = (v: string): { value: string; unit?: string } => {
    const m = v.match(/^(\S+)\s+(.+)$/);
    return m ? { value: m[1], unit: m[2] } : { value: v };
  };
  boldProps = {
    eyebrow: s.eyebrow ?? {
      label: 'Raport Fuse Collective',
      category: 'Badanie przewag konkurencyjnych',
    },
    headline: s.headline,
    subtitle: s.authorHeadline ?? s.subtitle,
    metricsLabel: s.metricsLabel,
    metrics: (s.metrics ?? []).map((m: any) => {
      const parts = splitValue(m.value);
      return { ...parts, delta: m.note, label: m.label };
    }),
    cta: {
      ...s.cta,
      note: s.gateNote,
    },
    author: s.author,
    contextBody: s.authorBody ?? '',
    acquisition: s.disclaimer,
  };
}
---

{type === 'report-cover' ? (
  <ReportCoverBoldSection {...boldProps} />
) : type === 'chapter-title' ? (
  <ChapterTitleSection {...section as any} />
) : type === 'pain-block' ? (
  <PainBlockSection {...section as any} />
) : type === 'overview' ? (
  <OverviewSection {...section as any} />
) : type === 'preview-gate' ? (
  <PreviewGateSection {...section as any} />
) : type === 'methodology' ? (
  <MethodologySection {...section as any} />
) : type === 'analysis' ? (
  <AnalysisSection {...section as any} />
) : type === 'constellation' ? (
  <ConstellationSection {...section as any} />
) : type === 'offer-cards' ? (
  <OfferCardsSection {...section as any} />
) : type === 'services-grid' ? (
  <ServicesSection {...section as any} />
) : (
  <section class="py-monumental px-page-gutter bg-surface-light" data-section-type={type}>
    <p class="text-label-sm text-text-muted font-body">[{type}]</p>
    {headline && <h2 class="text-display-lg text-on-surface-dark font-body">{headline}</h2>}
    <p class="text-body-sm text-text-muted font-body mt-compact">Placeholder — template not yet built.</p>
  </section>
)}
