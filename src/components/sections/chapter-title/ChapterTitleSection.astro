---
/**
 * ChapterTitleSection — dark chapter divider using SectionIntro.
 * Source: wireframes/brand24-raport_raport.md §Chapter
 * Left: chapter label + headline. Right: indicator circle + subtitle.
 */
import SectionIntro from '../../ui/SectionIntro.astro';

type Surface = 'light' | 'muted' | 'dark' | 'accent';

interface Props {
  headline: string;
  subtitle?: string;
  chapterLabel?: string;
  surface?: Surface;
}

const { headline, subtitle = '', chapterLabel, surface = 'dark' } = Astro.props;

const bgClass: Record<Surface, string> = {
  light: 'bg-surface-light',
  muted: 'bg-surface-muted',
  dark: 'bg-surface-dark',
  accent: 'bg-surface-accent',
};
---

<section
  class:list={[bgClass[surface], 'py-comfortable lg:py-monumental px-page-gutter']}
  data-surface={surface}
  data-section-type="chapter-title"
>
  <div class="mx-auto max-w-content-max">
    <SectionIntro headline={headline} body={subtitle} indicator="right">
      {chapterLabel && (
        <span
          slot="left-extra"
          class="inline-block font-body text-label-sm uppercase tracking-wide text-primary border border-primary px-compact py-tight self-start order-first"
        >
          {chapterLabel}
        </span>
      )}
    </SectionIntro>
  </div>
</section>
