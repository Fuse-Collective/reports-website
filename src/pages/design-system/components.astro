<script>
  const bgMap: Record<string, string> = {
    light: 'bg-surface-light', muted: 'bg-surface-muted',
    dark: 'bg-surface-dark', accent: 'bg-surface-accent',
  };
  const allBg = Object.values(bgMap);
  const on = 'bg-on-surface-dark text-on-surface-light';
  const off = 'hover:bg-surface-muted';

  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-dim]') as HTMLElement;
    if (!btn) return;
    const comp = btn.closest('.ds-component') as HTMLElement;
    if (!comp) return;

    const dim = btn.dataset.dim!;   // "surface", "icon", "indicator"
    const val = btn.dataset.value!;  // "light", "arrow", "with", etc.

    // Update active state on switcher buttons for this dimension
    comp.querySelectorAll(`[data-dim="${dim}"]`).forEach((b) => {
      b.classList.remove(...on.split(' '));
      b.classList.add(...off.split(' '));
    });
    btn.classList.remove(...off.split(' '));
    btn.classList.add(...on.split(' '));

    if (dim === 'surface') {
      // Show matching panel, hide others
      comp.querySelectorAll('.ds-panel').forEach((panel) => {
        const el = panel as HTMLElement;
        el.classList.toggle('hidden', el.dataset.panelSurface !== val);
      });
    } else {
      // Toggle rows by data-row-{dim}
      comp.querySelectorAll(`[data-row-${dim}]`).forEach((row) => {
        const el = row as HTMLElement;
        el.classList.toggle('hidden', el.getAttribute(`data-row-${dim}`) !== val);
      });
    }
  });
</script>
