  ],
  comparisonHeading: 'Porównanie z konkurencją',
  comparison: {
    columns: ['Aspekt', 'Brandwatch', 'Meltwater', 'Brand24'],
    highlightedColumnIndex: 3,
    rows: [
      ['Wdrożenie', 'Dedykowane wdrożenie', 'Guided demo', 'Konfiguracja w minuty'],
      ['Wnioski', 'Praca własna', 'Panele danych', 'AI generuje gotowe'],
      ['Cennik', 'Brak publicznego', 'Brak publicznego', 'Publiczny'],
      ['Cena wejścia', 'Indywidualna wycena', 'Indywidualna wycena', '$199/mies. (rocznie)'],
    ],
  },
  risksHeading: 'Gdzie leży ryzyko?',
  risks: [
    { icon: 'control-point-duplicate', title: 'Kopiowalność', body: 'Trudna w krótkim terminie. Wymaga połączenia danych (25 mln źródeł), UX, AI osadzonego w przepływie pracy i tempa wydawania nowych wersji. Kopiowalna w średnim terminie przez duże platformy, jeśli uznają segment MŚP za strategiczny.' },
    { icon: 'visibility-lock', title: 'Ograniczenie kategorii', body: 'Niedokładny sentyment to systemowa wada całej branży, nie specyficzny problem Brand24. Żadne narzędzie social listening nie rozwiązało tego w pełni. Szum w wynikach występuje u wszystkich graczy.' },
  ],
};
---

<PreviewLayout title="Section Templates" current="/design-system/sections/">

  {/* OfferCardsSection */}
  <div class="surface-preview" data-default-surface="muted">
    <div class="flex items-center gap-compact px-page-gutter pt-comfortable pb-compact">
      <h2 class="font-body text-headline-sm text-on-surface-dark">OfferCardsSection</h2>
      <div class="flex gap-tight ml-auto surface-buttons">
        <button data-surface-target="light" class="px-compact py-tight font-body text-label-sm border border-outline-light rounded-button cursor-pointer hover:bg-surface-muted">light</button>
        <button data-surface-target="muted" class="px-compact py-tight font-body text-label-sm border border-outline-light rounded-button cursor-pointer bg-on-surface-dark text-on-surface-light">muted</button>
        <button data-surface-target="dark" class="px-compact py-tight font-body text-label-sm border border-outline-light rounded-button cursor-pointer hover:bg-surface-muted">dark</button>
        <button data-surface-target="accent" class="px-compact py-tight font-body text-label-sm border border-outline-light rounded-button cursor-pointer hover:bg-surface-muted">accent</button>
      </div>
    </div>
    <OfferCardsSection
      headline="Specjalizujemy się w kompleksowych projektach z dwóch obszarów"
      description="Pracujemy z liderami lub pretendentami bardzo różnych branż nad rozwiązaniem złożonych problemów brandingowych."
      cards={offerCards}
      as="h1"
    />
  </div>

  {/* ServicesSection */}
  <div class="surface-preview" data-default-surface="dark">
    <div class="flex items-center gap-compact px-page-gutter pt-comfortable pb-compact">
      <h2 class="font-body text-headline-sm text-on-surface-dark">ServicesSection</h2>
      <div class="flex gap-tight ml-auto surface-buttons">
        <button data-surface-target="light" class="px-compact py-tight font-body text-label-sm border border-outline-light rounded-button cursor-pointer hover:bg-surface-muted">light</button>
        <button data-surface-target="muted" class="px-compact py-tight font-body text-label-sm border border-outline-light rounded-button cursor-pointer hover:bg-surface-muted">muted</button>
        <button data-surface-target="dark" class="px-compact py-tight font-body text-label-sm border border-outline-light rounded-button cursor-pointer bg-on-surface-dark text-on-surface-light">dark</button>
        <button data-surface-target="accent" class="px-compact py-tight font-body text-label-sm border border-outline-light rounded-button cursor-pointer hover:bg-surface-muted">accent</button>
      </div>
    </div>
    <ServicesSection
      headline="Klienci wybierają nas i zostają z nami na dłużej"
      body="Widząc efekty rozumieją, że jesteśmy inni niż agencje, z którymi wcześniej pracowali."
      services={services}
    />
  </div>

  {/* PainBlockSection */}
  <div class="surface-preview" data-default-surface="light">
    <div class="flex items-center gap-compact px-page-gutter pt-comfortable pb-compact">
      <h2 class="font-body text-headline-sm text-on-surface-dark">PainBlockSection</h2>
      <div class="flex gap-tight ml-auto surface-buttons">
        <button data-surface-target="light" class="px-compact py-tight font-body text-label-sm border border-outline-light rounded-button cursor-pointer bg-on-surface-dark text-on-surface-light">light</button>
        <button data-surface-target="muted" class="px-compact py-tight font-body text-label-sm border border-outline-light rounded-button cursor-pointer hover:bg-surface-muted">muted</button>
        <button data-surface-target="dark" class="px-compact py-tight font-body text-label-sm border border-outline-light rounded-button cursor-pointer hover:bg-surface-muted">dark</button>
        <button data-surface-target="accent" class="px-compact py-tight font-body text-label-sm border border-outline-light rounded-button cursor-pointer hover:bg-surface-muted">accent</button>
      </div>
    </div>
    <PainBlockSection
      headline="5 sygnałów problemu z wyróżnieniem"
      consequenceLabel="Co to oznacza w liczbach"
      consequences={[
        { text: "Wyższe koszty pozyskania klienta" },
        { text: "Dłuższa sprzedaż, niższe zaufanie" },
        { text: "Brak premii cenowej" },
        { text: "Łatwość substytucji" },
      ]}
      symptoms={painSymptoms}
    />
  </div>

  {/* ReportCoverSection */}
  <div>
    <h2 class="font-body text-headline-sm text-on-surface-dark px-page-gutter pt-comfortable pb-compact">ReportCoverSection</h2>
    <ReportCoverSection {...reportCover} />
  </div>

  {/* ChapterTitleSection */}
  <div>
    <h2 class="font-body text-headline-sm text-on-surface-dark px-page-gutter pt-comfortable pb-compact">ChapterTitleSection</h2>
    <ChapterTitleSection
      headline="Jak szukamy przewagi konkurencyjnej?"
      subtitle="Zanim pokażemy wyniki badania Brand24, zaczynamy od problemu i metodologii."
    />
  </div>

  {/* OverviewSection */}
  <div>
    <h2 class="font-body text-headline-sm text-on-surface-dark px-page-gutter pt-comfortable pb-compact">OverviewSection</h2>
    <OverviewSection
      headline="Co znaleźliśmy w Brand24"
      subtitle="Przeanalizowaliśmy Brand24 w 6 obszarach. W kilku wyniki są wyjątkowo silne."
      insightLabel="Kluczowy wniosek"
      insight="Brand24 ma realne przewagi konkurencyjne w branży social listening."
      insightPoints={[
        "<strong>Najsilniejsza: łamanie schematów kategorii</strong> — publiczny cennik, trial bez karty, miesięczne subskrypcje w branży, która to wszystko ukrywa.",
        "Nie wszystkie są jednakowo silne, ale te najsilniejsze są najtrudniejsze do skopiowania.",
      ]}
      areasLabel="6 obszarów przewagi"
      areas={overviewAreas}
      sectionPills={overviewPills}
      cta={{
        label: "Odblokuj pełną wersję",
        href: "#gate",
        note: "Pełna wersja raportu wymaga darmowej subskrypcji, dającej dostęp do sekcji z konstelacją przewag i oceną strategiczną. Zyskasz również dostęp do naszej wewnętrznej bazy raportów wraz z wnioskami i praktycznymi wskazówkami.",
      }}
    />
  </div>

  {/* AnalysisSection */}
  <div>
    <h2 class="font-body text-headline-sm text-on-surface-dark px-page-gutter pt-comfortable pb-compact">AnalysisSection</h2>
    <AnalysisSection {...analysisArea01} />
  </div>

</PreviewLayout>

<script>
  const bgMap: Record<string, string> = {
    light: 'bg-surface-light',
    muted: 'bg-surface-muted',
    dark: 'bg-surface-dark',
    accent: 'bg-surface-accent',
  };
  const allBgClasses = Object.values(bgMap);
  const activeBtn = 'bg-on-surface-dark text-on-surface-light';
  const inactiveBtn = 'hover:bg-surface-muted';

  document.querySelectorAll('.surface-preview').forEach((preview) => {
    const section = preview.querySelector('section[data-surface]') as HTMLElement;
    if (!section) return;

    preview.querySelectorAll('[data-surface-target]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const surface = (btn as HTMLElement).dataset.surfaceTarget!;

        // Update section
        section.dataset.surface = surface;
        section.classList.remove(...allBgClasses);
        section.classList.add(bgMap[surface]);

        // Update active button state
        preview.querySelectorAll('[data-surface-target]').forEach((b) => {
          b.classList.remove(...activeBtn.split(' '));
          b.classList.add(...inactiveBtn.split(' '));
        });
        btn.classList.remove(...inactiveBtn.split(' '));
        btn.classList.add(...activeBtn.split(' '));
      });
    });
  });
</script>
