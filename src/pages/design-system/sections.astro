const services = [
  { heading: "Tworzymy strategie marek i doradzamy", icon: "strategia", description: "Nie musisz znać się na wizerunku, to nasza specjalizacja. Wystarczy, że znasz swój biznes." },
  { heading: "Projektujemy identyfikacje wizualne i komunikację", icon: "identyfikacja", description: "Rozbudowane systemy identyfikacji wizualnej oraz materiały marketingowe to namacalne efekty naszej pracy." },
  { heading: "Budujemy systemy komunikacji", icon: "komunikacja", description: "Odpowiednio dobrane słowa i treści pomagają budować zaufanie oraz w zrozumiały sposób opowiadają o marce." },
  { heading: "Dopasowujemy autorski proces do kontekstu", icon: "proces", description: "Przez 10 lat wypracowaliśmy powtarzalne podejście tworzenia, badania i ulepszania rozwiązań." },
  { heading: "Realizujemy złożone projekty dla liderów", icon: "lider", description: "Pracujemy z liderami lub pretendentami nad złożonymi problemami, lub gdy marka wymaga głębszych zmian." },
  { heading: "Dajemy świeże spojrzenie", icon: "spojrzenie", description: "Synergia doświadczeń z różnych branż zapewnia świeżość, a przywiązanie do detalu wysoką jakość oraz estetykę." },
];

const reportCover = {
