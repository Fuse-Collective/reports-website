const overviewAreas = [
  { number: '01', label: 'Bolączki kategorii', state: 'done' as const },
  { number: '02', label: 'Łamanie schematów', state: 'done' as const },
  { number: '03', label: 'DNA firmy', state: 'done' as const },
  { number: '04', label: 'Demokratyzacja', state: 'done' as const },
  { number: '05', label: 'Kombinacje wartości', state: 'done' as const },
  { number: '06', label: 'Nowa podkategoria', state: 'done' as const },
];

const overviewPills = [
  { label: 'Konstelacje przewag', state: 'locked' as const },
  { label: 'Ocena strategiczna', state: 'locked' as const },
];

const analysisArea01 = {
  number: '01',
  title: 'Bolączki kategorii: AI zamiast ręcznej analizy',
  intro: 'Kategoria social listening ma chroniczne problemy: narzędzia zbierają tysiące wzmianek, ale użytkownik sam musi wydobyć wnioski. Konfiguracja trwa tygodnie. Analiza sentymentu jest niedokładna.',
  headerIcon: 'areas/target-click',
  insightsHeading: 'Główne wnioski',
  insights: [
    { title: 'AI zamiast surowych danych', description: 'Konkurencja daje panele danych. Brand24 daje odpowiedzi. AI Brand Assistant pozwala zadać pytanie w języku naturalnym i dostać gotowy wniosek. AI Insights generuje automatyczne raporty z trendami.' },
    { title: 'Sentyment z 95% skutecznością', description: 'AI Sentiment Analysis osiąga 95% F1 score na próbie 50 tys. wzmianek. Konkurencja? "Niedokładny sentyment" to stały motyw w recenzjach Brandwatch i Meltwater.' },
