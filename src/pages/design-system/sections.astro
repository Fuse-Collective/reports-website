      { label: "Zasięg", value: "154 kraje, 4 000+ klientów" },
    ],
  },
  metricsLabel: "Kluczowe metryki",
  metrics: [
    { label: "Przychody 2024", value: "35,28 mln zł", note: "+27% r/r" },
    { label: "MRR Q4 2025", value: "973 tys. USD", note: "+34% r/r" },
    { label: "ARPU Q4 2025", value: "264 USD", note: "+38% r/r" },
    { label: "Wzrost MRR", value: "16 kw. dynamicznego wzrostu z rzędu" },
  ],
  disclaimer: "W 2024 Semrush (przez Prowly) przejął ~57,6% akcji Brand24. W 2025 Adobe ogłosiło przejęcie Semrush za ~1,9 mld USD (zamknięcie oczekiwane H1 2026).",
  authorHeadline: "To nie jest artykuł o Brand24, tylko raport z badania przewag konkurencyjnych.",
  authorBody: "W badaniu wykorzystaliśmy framework, który stosujemy z firmami B2B: przemysł, technologia, produkcja, SaaS. Nasze prace dla klientów są poufne. Brand24 wybraliśmy celowo: publiczna spółka, znana marka, pełna transparentność danych.",
  author: {
    name: "Tomasz Maciąg",
    role: "CEO i strateg · Fuse Collective",
    photoUrl: "/images/authors/tomasz-maciag.png",
  },
  cta: {
    primary: { label: "Zobacz wyniki badania", href: "#s2" },
    secondary: { label: "Odblokuj pełną wersję", href: "#gate" },
  },
  gateNote: "Pełna wersja raportu wymaga darmowej subskrypcji, dającej dostęp do sekcji z konstelacją przewag i oceną strategiczną. Zyskasz również dostęp do naszej wewnętrznej bazy raportów wraz z wnioskami i praktycznymi wskazówkami.",
