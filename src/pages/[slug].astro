---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NavBar from '../components/sections/nav-bar/NavBar.astro';
import SectionRenderer from '../components/sections/SectionRenderer.astro';
import ReportSideNav from '../components/interactive/ReportSideNav.astro';
import MenuScope from '../components/interactive/MenuScope.astro';
import UnlockModal from '../components/interactive/UnlockModal.astro';
import GatedSections from '../components/GatedSections.astro';
import OverviewHero from '../components/sections/overview/OverviewHero.astro';
import OverviewInsight from '../components/sections/overview/OverviewInsight.astro';

// Global kill-switch for the subscription gate. When `false`, the report
// renders fully open: gated sections appear inline, the preview-gate teaser
// is hidden, the modal isn't mounted, and no client fetch fires. Useful for
// preview / review periods. Set in `.env.local` and Vercel env.
const gatingEnabled = import.meta.env.GATING_ENABLED !== 'false';

export async function getStaticPaths() {
  const reports = await getCollection('reports');
  return reports.map((report) => ({
    params: { slug: report.id },
    props: { report },
  }));
}

const { report } = Astro.props;
const { title, description, sections } = report.data;

// Primary (pre-gate, accent) overview drives the shared TOC data
// (areas + sectionPills). Post-gate dark overview re-uses the same TOC.
const primaryIdx = sections.findIndex((s) => s.type === 'overview');
// Post-gate overview = any subsequent overview section (regardless of surface).
const darkIdx = sections.findIndex(
  (s, i) => i > primaryIdx && s.type === 'overview'
);
// Optional THIRD overview = chapter opener for the post-constellations chapter
// (insights + strategic-assessment). When present, splits scope2 in two so
// each chapter gets its own MenuScope rail.
const insightsOverviewIdx = darkIdx !== -1
  ? sections.findIndex((s, i) => i > darkIdx && s.type === 'overview')
  : -1;
const previewGateIdx = sections.findIndex((s) => s.type === 'preview-gate');
const ctaIdx = sections.findIndex((s) => s.type === 'cta');
// Menu boundary: TOC scope closes BEFORE this section so the closing
// offer-cards / cta / about sections render full-width, without the sticky
// right-rail overlay. Identified by anchorId on the yaml entry.
const menuEndIdx = sections.findIndex(
  (s) => (s as any).anchorId === 'oferta'
);

const primaryData = primaryIdx !== -1 ? sections[primaryIdx] : null;
const darkData = darkIdx !== -1 ? sections[darkIdx] : null;
const insightsOverviewData = insightsOverviewIdx !== -1 ? sections[insightsOverviewIdx] : null;
const previewGateData = previewGateIdx !== -1 ? sections[previewGateIdx] : null;

const sideNav = primaryData
  ? {
      areasLabel: primaryData.areasLabel,
      areas: primaryData.areas,
      sectionPills: primaryData.sectionPills ?? [],
    }
  : null;

// Structural anchors — the page has three TOC regions, each anchored on an
// OVERVIEW INSIGHT. Heroes always render OUTSIDE scope (full-width):
//   Scope 1 (sticky):     primary overview INSIGHT → first of {preview-gate,
//                         dark overview, cta, end}. Primary analysis loop.
//                         TOC mode = 'areas'.
//   Preview-gate + between (sticky): preview-gate INSIGHT through methodology
//                         and any other sections before the dark overview.
//                         The menu follows the reader (sticky={true}) and
//                         releases at the next sectioning point (dark
//                         overview or end). TOC mode = 'constellations'.
//   Scope 2 (sticky):     dark overview INSIGHT → first of {cta, end}.
//                         Post-gate chapter. TOC mode = 'constellations'.
const scope1End = Math.min(
  previewGateIdx !== -1 ? previewGateIdx : Infinity,
  darkIdx !== -1 ? darkIdx : Infinity,
  ctaIdx !== -1 ? ctaIdx : Infinity,
  menuEndIdx !== -1 ? menuEndIdx : Infinity,
  sections.length,
);
const betweenEnd = darkIdx !== -1
  ? darkIdx
  : Math.min(
      ctaIdx !== -1 ? ctaIdx : Infinity,
      menuEndIdx !== -1 ? menuEndIdx : Infinity,
      sections.length,
    );
// scope2 (constellations) closes at the insights chapter opener if present,
// otherwise at the menu-end / cta / page end. scope3 (insights + strategic-
// assessment) covers from the insights overview to the menu-end / cta / page end.
const scope2End = Math.min(
  insightsOverviewIdx !== -1 ? insightsOverviewIdx : Infinity,
  ctaIdx !== -1 ? ctaIdx : Infinity,
  menuEndIdx !== -1 ? menuEndIdx : Infinity,
  sections.length,
);
const scope3End = Math.min(
  ctaIdx !== -1 ? ctaIdx : Infinity,
  menuEndIdx !== -1 ? menuEndIdx : Infinity,
  sections.length,
);

const preMenuRaw = primaryIdx !== -1 ? sections.slice(0, primaryIdx) : sections;

// In open mode (gating disabled), scrub gate-related CTAs from the report
// cover so the hero doesn't render an "Odblokuj dostęp" button pointing at
// a missing #gate anchor or the gate-justification note.
const preMenu = gatingEnabled
  ? preMenuRaw
  : preMenuRaw.map((section: any) => {
      if (section.type !== 'report-cover') return section;
      const { secondary: _drop, ...primaryOnly } = section.cta ?? {};
      const { gateNote: _gateNote, ...rest } = section;
      return { ...rest, cta: primaryOnly };
    });
const scope1Content = primaryIdx !== -1 ? sections.slice(primaryIdx + 1, scope1End) : [];

// Transitional region (between scope 1 and scope 2). Preview-gate is
// special-cased inside this region: rendered explicitly with a non-sticky
// MenuScope around its insight. Remaining transitional sections render
// plain via SectionRenderer.
const pgInBetween = previewGateIdx !== -1 && previewGateIdx >= scope1End && previewGateIdx < betweenEnd;
const beforePreviewGate = pgInBetween
  ? sections.slice(scope1End, previewGateIdx)
  : sections.slice(scope1End, betweenEnd);
const afterPreviewGate = pgInBetween ? sections.slice(previewGateIdx + 1, betweenEnd) : [];

const scope2Content = darkIdx !== -1 ? sections.slice(darkIdx + 1, scope2End) : [];
const scope3Content = insightsOverviewIdx !== -1 ? sections.slice(insightsOverviewIdx + 1, scope3End) : [];

// Tail sections that ALWAYS render (regardless of gate state) — placed
// after the gated mount in the page flow. Currently: offer-cards. Future:
// cta, about. Anything else stays inside the gated portion.
const ALWAYS_VISIBLE_TAIL_TYPES = new Set(['offer-cards', 'cta', 'about']);
const isAlwaysVisible = (s: any) =>
  ALWAYS_VISIBLE_TAIL_TYPES.has(s.type) || s.alwaysVisible === true;
// postMenu starts after the LAST sticky scope (scope3 if insights chapter
// opener exists, otherwise scope2). Always-visible offerings live here.
const postMenuRaw = sections.slice(scope3End);
const alwaysVisibleTail = postMenuRaw.filter(isAlwaysVisible);
const postMenu = postMenuRaw.filter((s: any) => !isAlwaysVisible(s));
---

<BaseLayout title={title} description={description} ogType="article">
  <NavBar surface="dark" />

  {preMenu.map((section) => (
    <SectionRenderer section={section} />
  ))}

  {primaryData && sideNav && (
    <>
      <OverviewHero
        headline={primaryData.headline}
        subtitle={primaryData.subtitle}
        anchorId="overview-areas"
      />

      <MenuScope
        areasLabel={sideNav.areasLabel}
        areas={sideNav.areas}
        areasHref="#overview-areas"
        sectionPills={sideNav.sectionPills}
      >
        <OverviewInsight
          insightLabel={primaryData.insightLabel}
          insight={primaryData.insight}
          insightPoints={primaryData.insightPoints}
          cta={gatingEnabled ? primaryData.cta : undefined}
          inMenuScope={true}
          photoUrl="/images/authors/tomasz-maciag.png"
          photoAlt="Tomasz Maciąg"
        />

        {scope1Content.map((section) => (
          <SectionRenderer section={section} inMenuScope={true} />
        ))}
      </MenuScope>
    </>
  )}

  {beforePreviewGate.map((section) => (
    <SectionRenderer section={section} />
  ))}

  {gatingEnabled && previewGateData && sideNav && (
    <>
      <OverviewHero headline={previewGateData.headline} anchorId="gate" surface="dark" />

      <MenuScope
        areasLabel={sideNav.areasLabel}
        areas={sideNav.areas}
        areasHref="#overview-areas"
        sectionPills={sideNav.sectionPills}
        mode="constellations"
        sticky={true}
        surface="dark"
      >
        <OverviewInsight
          insightLabel={previewGateData.insightLabel}
          insight={previewGateData.insight}
          insightPoints={previewGateData.insightPoints}
          cta={previewGateData.cta}
          inMenuScope={true}
          surface="dark"
          photoUrl="/images/authors/tomasz-maciag.png"
          photoAlt="Tomasz Maciąg"
        />
        {afterPreviewGate.map((section) => (
          <SectionRenderer section={section} inMenuScope={true} />
        ))}
      </MenuScope>
    </>
  )}

  {gatingEnabled && !previewGateData && afterPreviewGate.map((section) => (
    <SectionRenderer section={section} />
  ))}

  {gatingEnabled ? (
    /* Gated content mount point. Pre-gate sections render statically above;
       the dark overview, constellations 01-05, and Ocena strategiczna are
       fetched from /api/gated/[slug] by the client script below and inserted
       here. `display: contents` makes this wrapper invisible to layout, so
       the inserted children flow as siblings of the static sections above. */
    <div id="gated-content" data-slug={Astro.params.slug} style="display: contents;"></div>
  ) : (
    /* Gating disabled (preview / review mode): render the gated portion
       inline, server-side. No client fetch, no modal, fully public. */
    <GatedSections
      darkData={darkData}
      sideNav={sideNav}
      scope2Content={scope2Content}
      insightsOverviewData={insightsOverviewData}
      scope3Content={scope3Content}
      postMenu={postMenu}
    />
  )}

  {/* Always-visible tail (offer-cards, future cta/about). Renders at the end
      of the page regardless of gate state — sits OUTSIDE the gated fetch so
      non-subscribers see the conversion path even when the gate is closed. */}
  {alwaysVisibleTail.map((section) => (
    <SectionRenderer section={section} />
  ))}

  {sideNav && (
    <ReportSideNav
      areasLabel={sideNav.areasLabel}
      areas={sideNav.areas}
      areasHref="#overview-areas"
      sectionPills={sideNav.sectionPills}
    />
  )}

  {gatingEnabled && <UnlockModal />}
</BaseLayout>

<script>
  // Scroll-spy for the TOC: watches each analysis section and toggles
  // `data-current` on every matching `[data-area-number]` — with two
  // desktop TOC overlays + the mobile drawer, ALL items sharing the active
  // area get highlighted, which is correct (only one overlay is visible at
  // a time based on scroll position).
  //
  // "Active" zone: the top 40% of the viewport. A section becomes current
  // when its top edge enters that zone.
  const analysisSections = document.querySelectorAll<HTMLElement>('[data-section-type="analysis"]');
  const menuItems = document.querySelectorAll<HTMLElement>('[data-area-number]');

  if (analysisSections.length > 0 && menuItems.length > 0) {
    const setCurrent = (number: string | null) => {
      menuItems.forEach((item) => {
        const match = number !== null && item.getAttribute('data-area-number') === number;
        item.setAttribute('data-current', match ? 'true' : 'false');
      });
    };

    // Track visibility per section so we can pick the highest-up active one.
    const visible = new Map<string, number>(); // number -> intersectionRatio

    const pickCurrent = () => {
      if (visible.size === 0) return;
      // Choose the section whose top is closest to the top of the active band —
      // this is the one most "in view" for the reader.
      let best: { number: string; top: number } | null = null;
      for (const section of analysisSections) {
        const number = section.getAttribute('data-analysis-number');
        if (!number || !visible.has(number)) continue;
        const rect = section.getBoundingClientRect();
        if (!best || Math.abs(rect.top) < Math.abs(best.top)) {
          best = { number, top: rect.top };
        }
      }
      if (best) setCurrent(best.number);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const number = (entry.target as HTMLElement).getAttribute('data-analysis-number');
          if (!number) continue;
          if (entry.isIntersecting) visible.set(number, entry.intersectionRatio);
          else visible.delete(number);
        }
        pickCurrent();
      },
      {
        // Active band: top 40% of viewport (from 0% to 60% from bottom).
        rootMargin: '0px 0px -60% 0px',
        threshold: [0, 0.1, 0.5, 1],
      }
    );

    analysisSections.forEach((s) => observer.observe(s));
  }

  // Same pattern for constellations — toggles `data-current` on every matching
  // `[data-constellation-number]` menu item based on which constellation section
  // is currently in the top 40% of the viewport.
  //
  // Constellation sections live in the GATED portion of the report, fetched
  // from /api/gated/[slug] AFTER page load. Init runs both on DOMContentLoaded
  // (no-op when the gate is closed) and again after gated content is injected.
  function initConstellationScrollSpy() {
    const constellationSections = document.querySelectorAll<HTMLElement>('[data-section-type="constellation"]');
    const constellationMenuItems = document.querySelectorAll<HTMLElement>('li[data-constellation-number]');
    if (constellationSections.length === 0 || constellationMenuItems.length === 0) return;

    const setCurrentConstellation = (number: string | null) => {
      constellationMenuItems.forEach((item) => {
        const match = number !== null && item.getAttribute('data-constellation-number') === number;
        item.setAttribute('data-current', match ? 'true' : 'false');
      });
    };

    const visibleC = new Map<string, number>();

    const pickCurrentC = () => {
      if (visibleC.size === 0) return;
      let best: { number: string; top: number } | null = null;
      for (const section of constellationSections) {
        const number = section.getAttribute('data-constellation-number');
        if (!number || !visibleC.has(number)) continue;
        const rect = section.getBoundingClientRect();
        if (!best || Math.abs(rect.top) < Math.abs(best.top)) {
          best = { number, top: rect.top };
        }
      }
      if (best) setCurrentConstellation(best.number);
    };

    const observerC = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const number = (entry.target as HTMLElement).getAttribute('data-constellation-number');
          if (!number) continue;
          if (entry.isIntersecting) visibleC.set(number, entry.intersectionRatio);
          else visibleC.delete(number);
        }
        pickCurrentC();
      },
      {
        rootMargin: '0px 0px -60% 0px',
        threshold: [0, 0.1, 0.5, 1],
      }
    );

    constellationSections.forEach((s) => observerC.observe(s));
  }

  // Initial pass — no-ops in normal flow (constellations are gated and not
  // in static HTML). Kept for symmetry with analysis scroll-spy + future
  // reports that might inline constellations.
  initConstellationScrollSpy();

  // Expose for the unlock modal to call after a successful unlock injects
  // gated content (it can't import this script's local function directly).
  (window as unknown as { initConstellationScrollSpy: () => void }).initConstellationScrollSpy = initConstellationScrollSpy;

  // Fetch and inject the gated portion. 401 = no/invalid cookie or
  // unsubscribed — leave mount empty so the gate teaser stays visible.
  // Any non-OK status is treated the same way (silent gate).
  //
  // First: if the URL carries `?email=...` (sent in MailerLite emails to
  // existing subscribers), call /api/auto-unlock so the gated fetch below
  // succeeds without showing the modal. Strip the param from the address
  // bar regardless of result so the email isn't left in browser history.
  const mount = document.getElementById('gated-content');
  if (mount) {
    const slug = mount.dataset.slug;
    if (slug) {
      (async () => {
        const params = new URLSearchParams(window.location.search);
        // URLSearchParams decodes `+` as a space (form-encoding rule).
        // Subscriber emails commonly contain `+` (Gmail aliases) — recover it.
        const emailParam = params.get('email')?.replace(/ /g, '+') ?? null;
        if (emailParam) {
          try {
            await fetch('/api/auto-unlock', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ email: emailParam }),
              credentials: 'same-origin',
            });
          } catch (err) {
            console.error('Auto-unlock failed:', err);
          }
          params.delete('email');
          const cleanUrl =
            window.location.pathname +
            (params.toString() ? '?' + params.toString() : '') +
            window.location.hash;
          window.history.replaceState(null, '', cleanUrl);
        }

        try {
          const r = await fetch(`/api/gated/${slug}`, { credentials: 'same-origin' });
          if (!r.ok) return;
          const html = await r.text();
          // Empty body = gate locked (204 No Content). Leave teaser visible.
          if (!html) return;
          mount.insertAdjacentHTML('beforeend', html);
          // Mark gate state so [data-gate-locked] elements (unlock CTAs,
          // gate teasers) hide via the CSS rule in global.css.
          document.body.dataset.gateState = 'unlocked';
          // Re-scan now that constellation sections + their menu items exist.
          initConstellationScrollSpy();
        } catch (err) {
          console.error('Gated content fetch failed:', err);
        }
      })();
    }
  }
</script>
