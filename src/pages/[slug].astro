---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NavBar from '../components/sections/nav-bar/NavBar.astro';
import SectionRenderer from '../components/sections/SectionRenderer.astro';
import ReportSideNav from '../components/interactive/ReportSideNav.astro';
import MenuScope from '../components/interactive/MenuScope.astro';
import OverviewHero from '../components/sections/overview/OverviewHero.astro';
import OverviewInsight from '../components/sections/overview/OverviewInsight.astro';

export async function getStaticPaths() {
  const reports = await getCollection('reports');
  return reports.map((report) => ({
    params: { slug: report.id },
    props: { report },
  }));
}

const { report } = Astro.props;
const { title, description, sections } = report.data;

// Primary (pre-gate, accent) overview drives the shared TOC data
// (areas + sectionPills). Post-gate dark overview re-uses the same TOC.
const primaryIdx = sections.findIndex((s) => s.type === 'overview');
// Post-gate overview = any subsequent overview section (regardless of surface).
const darkIdx = sections.findIndex(
  (s, i) => i > primaryIdx && s.type === 'overview'
);
const previewGateIdx = sections.findIndex((s) => s.type === 'preview-gate');
const ctaIdx = sections.findIndex((s) => s.type === 'cta');
// Menu boundary: TOC scope closes BEFORE this section so the closing
// strategic-assessment + CTA + about sections render full-width, without
// the sticky right-rail overlay. Identified by anchorId on the yaml entry.
const menuEndIdx = sections.findIndex(
  (s) => (s as any).anchorId === 'ocena-strategiczna'
);

const primaryData = primaryIdx !== -1 ? sections[primaryIdx] : null;
const darkData = darkIdx !== -1 ? sections[darkIdx] : null;
const previewGateData = previewGateIdx !== -1 ? sections[previewGateIdx] : null;

const sideNav = primaryData
  ? {
      areasLabel: primaryData.areasLabel,
      areas: primaryData.areas,
      sectionPills: primaryData.sectionPills ?? [],
    }
  : null;

// Structural anchors — the page has three TOC regions, each anchored on an
// OVERVIEW INSIGHT. Heroes always render OUTSIDE scope (full-width):
//   Scope 1 (sticky):     primary overview INSIGHT → first of {preview-gate,
//                         dark overview, cta, end}. Primary analysis loop.
//                         TOC mode = 'areas'.
//   Preview-gate + between (sticky): preview-gate INSIGHT through methodology
//                         and any other sections before the dark overview.
//                         The menu follows the reader (sticky={true}) and
//                         releases at the next sectioning point (dark
//                         overview or end). TOC mode = 'constellations'.
//   Scope 2 (sticky):     dark overview INSIGHT → first of {cta, end}.
//                         Post-gate chapter. TOC mode = 'constellations'.
const scope1End = Math.min(
  previewGateIdx !== -1 ? previewGateIdx : Infinity,
  darkIdx !== -1 ? darkIdx : Infinity,
  ctaIdx !== -1 ? ctaIdx : Infinity,
  menuEndIdx !== -1 ? menuEndIdx : Infinity,
  sections.length,
);
const betweenEnd = darkIdx !== -1
  ? darkIdx
  : Math.min(
      ctaIdx !== -1 ? ctaIdx : Infinity,
      menuEndIdx !== -1 ? menuEndIdx : Infinity,
      sections.length,
    );
const scope2End = Math.min(
  ctaIdx !== -1 ? ctaIdx : Infinity,
  menuEndIdx !== -1 ? menuEndIdx : Infinity,
  sections.length,
);

const preMenu = primaryIdx !== -1 ? sections.slice(0, primaryIdx) : sections;
const scope1Content = primaryIdx !== -1 ? sections.slice(primaryIdx + 1, scope1End) : [];

// Transitional region (between scope 1 and scope 2). Preview-gate is
// special-cased inside this region: rendered explicitly with a non-sticky
// MenuScope around its insight. Remaining transitional sections render
// plain via SectionRenderer.
const pgInBetween = previewGateIdx !== -1 && previewGateIdx >= scope1End && previewGateIdx < betweenEnd;
const beforePreviewGate = pgInBetween
  ? sections.slice(scope1End, previewGateIdx)
  : sections.slice(scope1End, betweenEnd);
const afterPreviewGate = pgInBetween ? sections.slice(previewGateIdx + 1, betweenEnd) : [];

const scope2Content = darkIdx !== -1 ? sections.slice(darkIdx + 1, scope2End) : [];
const postMenu = sections.slice(scope2End);
---

<BaseLayout title={title} description={description}>
  <NavBar surface="light" />

  {preMenu.map((section) => (
    <SectionRenderer section={section} />
  ))}

  {primaryData && sideNav && (
    <>
      <OverviewHero
        headline={primaryData.headline}
        subtitle={primaryData.subtitle}
        anchorId="overview-areas"
      />

      <MenuScope
        areasLabel={sideNav.areasLabel}
        areas={sideNav.areas}
        areasHref="#overview-areas"
        sectionPills={sideNav.sectionPills}
      >
        <OverviewInsight
          insightLabel={primaryData.insightLabel}
          insight={primaryData.insight}
          insightPoints={primaryData.insightPoints}
          cta={primaryData.cta}
          inMenuScope={true}
        />

        {scope1Content.map((section) => (
          <SectionRenderer section={section} />
        ))}
      </MenuScope>
    </>
  )}

  {beforePreviewGate.map((section) => (
    <SectionRenderer section={section} />
  ))}

  {previewGateData && sideNav && (
    <>
      <OverviewHero headline={previewGateData.headline} anchorId="gate" />

      <MenuScope
        areasLabel={sideNav.areasLabel}
        areas={sideNav.areas}
        areasHref="#overview-areas"
        sectionPills={sideNav.sectionPills}
        mode="constellations"
        sticky={true}
      >
        <OverviewInsight
          insightLabel={previewGateData.insightLabel}
          insight={previewGateData.insight}
          insightPoints={previewGateData.insightPoints}
          cta={previewGateData.cta}
          inMenuScope={true}
        />
        {afterPreviewGate.map((section) => (
          <SectionRenderer section={section} />
        ))}
      </MenuScope>
    </>
  )}

  {!previewGateData && afterPreviewGate.map((section) => (
    <SectionRenderer section={section} />
  ))}

  {darkData && sideNav && (
    <>
      <OverviewHero
        headline={darkData.headline}
        subtitle={darkData.subtitle}
        surface={(darkData as any).surface ?? 'accent'}
        anchorId="overview-constellations"
      />

      <MenuScope
        areasLabel={sideNav.areasLabel}
        areas={sideNav.areas}
        areasHref="#overview-areas"
        sectionPills={sideNav.sectionPills}
        mode="constellations"
      >
        <OverviewInsight
          insightLabel={darkData.insightLabel}
          insight={darkData.insight}
          insightPoints={darkData.insightPoints}
          cta={darkData.cta}
          surface={(darkData as any).surface ?? 'accent'}
          inMenuScope={true}
        />

        {scope2Content.map((section) => (
          <SectionRenderer section={section} />
        ))}
      </MenuScope>
    </>
  )}

  {postMenu.map((section) => (
    <SectionRenderer section={section} />
  ))}

  {sideNav && (
    <ReportSideNav
      areasLabel={sideNav.areasLabel}
      areas={sideNav.areas}
      areasHref="#overview-areas"
      sectionPills={sideNav.sectionPills}
    />
  )}
</BaseLayout>

<script>
  // Scroll-spy for the TOC: watches each analysis section and toggles
  // `data-current` on every matching `[data-area-number]` — with two
  // desktop TOC overlays + the mobile drawer, ALL items sharing the active
  // area get highlighted, which is correct (only one overlay is visible at
  // a time based on scroll position).
  //
  // "Active" zone: the top 40% of the viewport. A section becomes current
  // when its top edge enters that zone.
  const analysisSections = document.querySelectorAll<HTMLElement>('[data-section-type="analysis"]');
  const menuItems = document.querySelectorAll<HTMLElement>('[data-area-number]');

  if (analysisSections.length > 0 && menuItems.length > 0) {
    const setCurrent = (number: string | null) => {
      menuItems.forEach((item) => {
        const match = number !== null && item.getAttribute('data-area-number') === number;
        item.setAttribute('data-current', match ? 'true' : 'false');
      });
    };

    // Track visibility per section so we can pick the highest-up active one.
    const visible = new Map<string, number>(); // number -> intersectionRatio

    const pickCurrent = () => {
      if (visible.size === 0) return;
      // Choose the section whose top is closest to the top of the active band —
      // this is the one most "in view" for the reader.
      let best: { number: string; top: number } | null = null;
      for (const section of analysisSections) {
        const number = section.getAttribute('data-analysis-number');
        if (!number || !visible.has(number)) continue;
        const rect = section.getBoundingClientRect();
        if (!best || Math.abs(rect.top) < Math.abs(best.top)) {
          best = { number, top: rect.top };
        }
      }
      if (best) setCurrent(best.number);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const number = (entry.target as HTMLElement).getAttribute('data-analysis-number');
          if (!number) continue;
          if (entry.isIntersecting) visible.set(number, entry.intersectionRatio);
          else visible.delete(number);
        }
        pickCurrent();
      },
      {
        // Active band: top 40% of viewport (from 0% to 60% from bottom).
        rootMargin: '0px 0px -60% 0px',
        threshold: [0, 0.1, 0.5, 1],
      }
    );

    analysisSections.forEach((s) => observer.observe(s));
  }

  // Same pattern for constellations — toggles `data-current` on every matching
  // `[data-constellation-number]` menu item based on which constellation section
  // is currently in the top 40% of the viewport.
  const constellationSections = document.querySelectorAll<HTMLElement>('[data-section-type="constellation"]');
  const constellationMenuItems = document.querySelectorAll<HTMLElement>('li[data-constellation-number]');

  if (constellationSections.length > 0 && constellationMenuItems.length > 0) {
    const setCurrentConstellation = (number: string | null) => {
      constellationMenuItems.forEach((item) => {
        const match = number !== null && item.getAttribute('data-constellation-number') === number;
        item.setAttribute('data-current', match ? 'true' : 'false');
      });
    };

    const visibleC = new Map<string, number>();

    const pickCurrentC = () => {
      if (visibleC.size === 0) return;
      let best: { number: string; top: number } | null = null;
      for (const section of constellationSections) {
        const number = section.getAttribute('data-constellation-number');
        if (!number || !visibleC.has(number)) continue;
        const rect = section.getBoundingClientRect();
        if (!best || Math.abs(rect.top) < Math.abs(best.top)) {
          best = { number, top: rect.top };
        }
      }
      if (best) setCurrentConstellation(best.number);
    };

    const observerC = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const number = (entry.target as HTMLElement).getAttribute('data-constellation-number');
          if (!number) continue;
          if (entry.isIntersecting) visibleC.set(number, entry.intersectionRatio);
          else visibleC.delete(number);
        }
        pickCurrentC();
      },
      {
        rootMargin: '0px 0px -60% 0px',
        threshold: [0, 0.1, 0.5, 1],
      }
    );

    constellationSections.forEach((s) => observerC.observe(s));
  }
</script>
