---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NavBar from '../components/sections/nav-bar/NavBar.astro';
import SectionRenderer from '../components/sections/SectionRenderer.astro';
import ReportSideNav from '../components/interactive/ReportSideNav.astro';
import ReportAreasMenu from '../components/common/ReportAreasMenu.astro';

export async function getStaticPaths() {
  const reports = await getCollection('reports');
  return reports.map((report) => ({
    params: { slug: report.id },
    props: { report },
  }));
}

const { report } = Astro.props;
const { title, description, sections } = report.data;

const overviewSection = sections.find((section) => section.type === 'overview');
const sideNav = overviewSection
  ? {
      areasLabel: overviewSection.areasLabel,
      areas: overviewSection.areas,
      sectionPills: overviewSection.sectionPills ?? [],
    }
  : null;

// Menu scope = from the `overview` section through the last section BEFORE
// the first `cta`. On xl+ the wrapper becomes a real 2-col CSS grid
// (content | sticky menu) — sections inside drop their own px-page-gutter
// and max-width constraints via their own `xl:` responsive overrides
// (see OverviewSection + AnalysisSection for the pattern). Starting the
// scope at `overview` (not at `analysis`) means the sticky menu appears
// alongside the overview row and keeps following as the user scrolls down
// instead of appearing only after overview has scrolled away.
// Below xl, the mobile drawer trigger in ReportSideNav handles TOC access.
const overviewIdx = sections.findIndex((s) => s.type === 'overview');
const firstCtaIdx = sections.findIndex((s) => s.type === 'cta');
const hasMenuScope = sideNav && overviewIdx !== -1;

const menuScopeStart = overviewIdx;
const menuScopeEnd = firstCtaIdx === -1 ? sections.length : firstCtaIdx;

const preMenu = hasMenuScope ? sections.slice(0, menuScopeStart) : sections;
const menuScope = hasMenuScope ? sections.slice(menuScopeStart, menuScopeEnd) : [];
const postMenu = hasMenuScope ? sections.slice(menuScopeEnd) : [];
---

<BaseLayout title={title} description={description}>
  <NavBar surface="light" />

  {preMenu.map((section) => (
    <SectionRenderer section={section} />
  ))}

  {hasMenuScope && (
    <div class="relative" data-menu-scope>
      {menuScope.map((section) => (
        <SectionRenderer section={section} />
      ))}

      {/* Desktop menu — absolutely positioned overlay aligned to the same
          content-max + page-gutter grid as the sections. Sections keep their
          own outer gutters and inner max-width, so outer responsive behavior
          is identical across pre-menu and menu-scope sections. Menu-scope
          sections reserve `xl:pr-[368px]` inside their content wrapper so
          content doesn't collide with the menu rail. */}
      <div class="hidden xl:block absolute inset-0 pointer-events-none" aria-hidden="true">
        <div class="h-full px-page-gutter">
          <div class="mx-auto max-w-content-max h-full relative">
            <aside
              class="absolute top-0 right-0 h-full w-[320px] pt-monumental pointer-events-auto"
              aria-label="Spis treści raportu"
              aria-hidden="false"
            >
              {/* `pt-monumental` on the parent aligns the menu's natural
                  position with the overview section's content top. Once the
                  user scrolls past that, sticky `top-[2rem]` kicks in and
                  the menu floats near the viewport top (32px margin) —
                  NavBar is absolute and scrolls away, so no overlap risk. */}
              <div class="sticky top-[2rem] w-fit ml-auto">
                <ReportAreasMenu
                  areasLabel={sideNav.areasLabel}
                  areas={sideNav.areas}
                  sectionPills={sideNav.sectionPills}
                />
              </div>
            </aside>
          </div>
        </div>
      </div>
    </div>
  )}

  {postMenu.map((section) => (
    <SectionRenderer section={section} />
  ))}

  {sideNav && (
    <ReportSideNav
      areasLabel={sideNav.areasLabel}
      areas={sideNav.areas}
      sectionPills={sideNav.sectionPills}
    />
  )}
</BaseLayout>

<script>
  // Scroll-spy for the TOC: watches each analysis section and toggles
  // `data-current` on every matching `[data-area-number]` (covers both the
  // desktop sticky overlay and the mobile drawer — they share ReportAreasMenu).
  //
  // "Active" zone: the top 40% of the viewport. A section becomes current
  // when its top edge enters that zone. This feels natural because the
  // heading is usually near the top of each section.
  const analysisSections = document.querySelectorAll<HTMLElement>('[data-section-type="analysis"]');
  const menuItems = document.querySelectorAll<HTMLElement>('[data-area-number]');

  if (analysisSections.length > 0 && menuItems.length > 0) {
    const setCurrent = (number: string | null) => {
      menuItems.forEach((item) => {
        const match = number !== null && item.getAttribute('data-area-number') === number;
        item.setAttribute('data-current', match ? 'true' : 'false');
      });
    };

    // Track visibility per section so we can pick the highest-up active one.
    const visible = new Map<string, number>(); // number -> intersectionRatio

    const pickCurrent = () => {
      if (visible.size === 0) return;
      // Choose the section whose top is closest to the top of the active band —
      // this is the one most "in view" for the reader.
      let best: { number: string; top: number } | null = null;
      for (const section of analysisSections) {
        const number = section.getAttribute('data-analysis-number');
        if (!number || !visible.has(number)) continue;
        const rect = section.getBoundingClientRect();
        if (!best || Math.abs(rect.top) < Math.abs(best.top)) {
          best = { number, top: rect.top };
        }
      }
      if (best) setCurrent(best.number);
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const number = (entry.target as HTMLElement).getAttribute('data-analysis-number');
          if (!number) continue;
          if (entry.isIntersecting) visible.set(number, entry.intersectionRatio);
          else visible.delete(number);
        }
        pickCurrent();
      },
      {
        // Active band: top 40% of viewport (from 0% to 60% from bottom).
        rootMargin: '0px 0px -60% 0px',
        threshold: [0, 0.1, 0.5, 1],
      }
    );

    analysisSections.forEach((s) => observer.observe(s));
  }
</script>
